    "/_full",
    "/!KGNvbW1lcmNlKQ/$d$segment/cart/__PAGE__",
    "/!KGNvbW1lcmNlKQ/$d$segment/cart",
    "/!KGNvbW1lcmNlKQ/$d$segment",
    "/!KGNvbW1lcmNlKQ",
    "/_index",
    "/_head"
  ]
}